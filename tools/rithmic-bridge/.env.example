# Copy to tools/rithmic-bridge/.env (do not commit secrets)

RITHMIC_USER=
RITHMIC_PASSWORD=
# Lucid system name as shown in R|Trader / Tradition dropdown (often LucidTrading / similar)
RITHMIC_SYSTEM=Rithmic Test
# WSS URL from Rithmic Dev Kit servers.toml (Test or production gateway)
RITHMIC_URL=
RITHMIC_APP_NAME=myapp-bridge
RITHMIC_APP_VERSION=1.0.0
RITHMIC_BRIDGE_PORT=7788
