# Copy to tools/rithmic-bridge/.env (do not commit secrets)

# Lucid live (R|Trader: System = LucidTrading, Gateway = Chicago Area)
RITHMIC_USER=
RITHMIC_PASSWORD=
RITHMIC_SYSTEM=LucidTrading
# Production Protocol WSS (not Test rituz00100)
RITHMIC_URL=wss://rprotocol.rithmic.com:443
RITHMIC_APP_NAME=myapp-bridge
RITHMIC_APP_VERSION=1.0.0
RITHMIC_BRIDGE_PORT=7788
RITHMIC_SSL_VERIFY=0
RITHMIC_TICK_HOURS=3
